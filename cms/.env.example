# Server
HOST=0.0.0.0
PORT=1337

# Secrets — generate each with: openssl rand -base64 32
APP_KEYS="key1,key2,key3,key4"
API_TOKEN_SALT=
ADMIN_JWT_SECRET=
TRANSFER_TOKEN_SALT=
ENCRYPTION_KEY=

# Database — SQLite for local dev; switch to postgres for production
DATABASE_CLIENT=sqlite
DATABASE_HOST=
DATABASE_PORT=
DATABASE_NAME=
DATABASE_USERNAME=
DATABASE_PASSWORD=
DATABASE_SSL=false
DATABASE_FILENAME=.tmp/data.db

# Production (Supabase Postgres) — uncomment and fill when deploying
# DATABASE_CLIENT=postgres
# DATABASE_HOST=your_supabase_db_host
# DATABASE_PORT=5432
# DATABASE_NAME=postgres
# DATABASE_USERNAME=postgres
# DATABASE_PASSWORD=
# DATABASE_SSL=true
# DATABASE_URL=

# Cloudinary (for media uploads in admin)
CLOUDINARY_NAME=yyuznnk7
CLOUDINARY_KEY=
CLOUDINARY_SECRET=

# ISR — Next.js revalidation webhook
# Must match REVALIDATE_SECRET in web/.env.local
FRONTEND_URL=http://localhost:3000
REVALIDATE_SECRET=
